---
import AdminActionButton from "../../../components/admin/AdminActionButton.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import AdminStatusBadge from "../../../components/admin/AdminStatusBadge.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { formatAdminDate, getAdminPostById } from "../../../lib/admin";

const post = await getAdminPostById(Astro.params.id ?? "");
if (!post) return Astro.redirect("/admin/posts", 303);
---

<AdminLayout title={`${post.title} - 理哩后台`}>
  <AdminPageHeader eyebrow="Posts / Edit" title={post.title} description="这里是文章编辑占位页。下一阶段会接入 Markdown 编辑器和保存发布流程。">
    <AdminActionButton href="/admin/posts">返回文章</AdminActionButton>
    <AdminActionButton href={`/posts/${post.slug}`}>前台查看</AdminActionButton>
  </AdminPageHeader>

  <section class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <div class="border border-dashed border-[var(--color-line)] bg-white p-8">
      <h2 class="font-serif-title text-2xl font-semibold">编辑器将在下一阶段实现</h2>
      <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">当前只展示文章元信息，不修改 Markdown 正文。</p>
      <pre class="mt-5 max-h-[360px] overflow-auto border border-[var(--color-line)] bg-[#f8f4ec] p-4 text-xs leading-6 text-[var(--color-muted)]">{post.markdown || "暂无正文"}</pre>
    </div>

    <aside class="border border-[var(--color-line)] bg-white p-5">
      <h2 class="font-serif-title text-xl font-semibold">文章元信息</h2>
      <dl class="mt-4 space-y-3 text-sm">
        <div><dt class="text-[var(--color-muted)]">状态</dt><dd class="mt-1"><AdminStatusBadge value={post.status} tone={post.status === "published" ? "green" : post.status === "draft" ? "amber" : "neutral"} /></dd></div>
        <div><dt class="text-[var(--color-muted)]">可见性</dt><dd class="mt-1"><AdminStatusBadge value={post.visibility} tone={post.visibility === "private" ? "blue" : "neutral"} /></dd></div>
        <div><dt class="text-[var(--color-muted)]">分类</dt><dd class="mt-1">{post.category?.name ?? "未分类"}</dd></div>
        <div><dt class="text-[var(--color-muted)]">标签</dt><dd class="mt-1">{post.tags.length > 0 ? post.tags.map((tag) => tag.name).join("、") : "无"}</dd></div>
        <div><dt class="text-[var(--color-muted)]">发布时间</dt><dd class="mt-1">{formatAdminDate(post.published_at)}</dd></div>
        <div><dt class="text-[var(--color-muted)]">更新时间</dt><dd class="mt-1">{formatAdminDate(post.updated_at)}</dd></div>
        <div><dt class="text-[var(--color-muted)]">Slug</dt><dd class="mt-1 break-all">{post.slug}</dd></div>
      </dl>
    </aside>
  </section>
</AdminLayout>
