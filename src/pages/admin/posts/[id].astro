---
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import AdminStatusBadge from "../../../components/admin/AdminStatusBadge.astro";
import PostEditor from "../../../components/admin/PostEditor";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAdminPostById, listAdminCategories, listAdminTags } from "../../../lib/admin";

const post = await getAdminPostById(Astro.params.id ?? "");
if (!post) return Astro.redirect("/admin/posts", 303);

const [categories, tags] = await Promise.all([listAdminCategories(), listAdminTags()]);
const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
---

<AdminLayout title={`${post.title} - 理哩后台`}>
  <AdminPageHeader eyebrow="Posts / Edit" title={post.title || "编辑文章"} description="编辑正文和文章设置；发布后公开文章会进入前台可见范围。">
    <AdminStatusBadge value={post.status} tone={post.status === "published" ? "green" : post.status === "draft" ? "amber" : "neutral"} />
    <AdminStatusBadge value={post.visibility} tone={post.visibility === "private" ? "blue" : "neutral"} />
  </AdminPageHeader>

  <PostEditor
    client:only="react"
    post={post}
    categories={categories}
    tags={tags}
    error={error}
    success={success}
  />
</AdminLayout>
