---
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import PostEditor from "../../../components/admin/PostEditor";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listAdminCategories, listAdminImageMedia, listAdminTags } from "../../../lib/admin";

const [categories, tags, mediaAssets] = await Promise.all([listAdminCategories(), listAdminTags(), listAdminImageMedia({ limit: 40 })]);
const uncategorized = categories.find((category) => category.name === "未分类");
const error = Astro.url.searchParams.get("error");
---

<AdminLayout title="新建文章 - 理哩后台">
  <AdminPageHeader eyebrow="Posts / New" title="新建文章" description="先保存草稿，再慢慢整理分类、标签和封面。正文保存为 Markdown。" />

  <PostEditor
    client:only="react"
    categories={categories}
    tags={tags}
    mediaAssets={mediaAssets}
    defaultCategoryId={uncategorized?.id ?? null}
    error={error}
  />
</AdminLayout>
