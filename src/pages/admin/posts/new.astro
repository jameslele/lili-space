---
import AdminActionButton from "../../../components/admin/AdminActionButton.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { listAdminCategories, listAdminTags } from "../../../lib/admin";

const [categories, tags] = await Promise.all([listAdminCategories(), listAdminTags()]);
---

<AdminLayout title="新建文章 - 理哩后台">
  <AdminPageHeader eyebrow="Posts / New" title="新建文章" description="第 7 阶段会在这里接入 Milkdown Crepe 编辑器；本阶段先固定文章设置和分类标签的接口位置。">
    <AdminActionButton href="/admin/posts">返回文章</AdminActionButton>
  </AdminPageHeader>

  <section class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <div class="border border-dashed border-[var(--color-line)] bg-white p-8">
      <h2 class="font-serif-title text-2xl font-semibold">编辑器占位</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">
        下一阶段会在主区域加载 Milkdown Crepe，只在写作路由引入编辑器资源。当前不实现保存、发布和正文编辑。
      </p>
    </div>

    <aside class="space-y-4">
      <section class="border border-[var(--color-line)] bg-white p-5">
        <h2 class="font-serif-title text-xl font-semibold">文章设置预留</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div><dt class="font-medium">分类单选</dt><dd class="mt-1 text-[var(--color-muted)]">从 {categories.length} 个分类中选择；未选择时归入「未分类」。</dd></div>
          <div><dt class="font-medium">新建分类</dt><dd class="mt-1 text-[var(--color-muted)]">写文章时会提供轻量入口，复用当前分类管理的 slug 规则。</dd></div>
          <div><dt class="font-medium">标签多选</dt><dd class="mt-1 text-[var(--color-muted)]">从 {tags.length} 个标签中选择，也支持即时输入新标签。</dd></div>
        </dl>
      </section>
      <section class="border border-[var(--color-line)] bg-white p-5">
        <h2 class="font-serif-title text-xl font-semibold">后续操作</h2>
        <div class="mt-4 grid gap-2">
          <AdminActionButton href="/admin/categories">管理分类</AdminActionButton>
          <AdminActionButton href="/admin/tags">管理标签</AdminActionButton>
        </div>
      </section>
    </aside>
  </section>
</AdminLayout>
