---
import AdminActionButton from "../../components/admin/AdminActionButton.astro";
import AdminEmptyState from "../../components/admin/AdminEmptyState.astro";
import AdminNotice from "../../components/admin/AdminNotice.astro";
import AdminPageHeader from "../../components/admin/AdminPageHeader.astro";
import AdminTable from "../../components/admin/AdminTable.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { formatAdminDate, listAdminMedia } from "../../lib/admin";

const assets = await listAdminMedia({ featuredOnly: true });
const success = Astro.url.searchParams.get("success");
const successMessage = {
  sorted: "照片顺序已更新。",
  featured: "精选状态已更新。",
  updated: "照片信息已更新。",
}[success ?? ""];
---

<AdminLayout title="Gallery - 理哩后台">
  <AdminPageHeader eyebrow="Gallery" title="照片精选" description="这里展示进入前台照片页的精选图片。">
    <AdminActionButton href="/admin/media">查看媒体</AdminActionButton>
  </AdminPageHeader>

  <AdminNotice message={successMessage} tone="success" />

  {assets.length > 0 ? (
    <AdminTable>
      <colgroup>
        <col class="w-24" />
        <col class="w-48" />
        <col class="w-20" />
        <col class="w-[320px]" />
        <col class="w-36" />
        <col class="w-36" />
        <col class="w-32" />
        <col class="w-28" />
      </colgroup>
      <thead class="bg-[#f8f4ec] text-xs uppercase tracking-[0.12em] text-[var(--color-muted)]">
        <tr>
          <th class="px-4 py-3 font-medium">预览</th>
          <th class="px-4 py-3 font-medium">文件</th>
          <th class="px-4 py-3 font-medium">可见性</th>
          <th class="px-4 py-3 font-medium">说明</th>
          <th class="px-4 py-3 font-medium">关联文章</th>
          <th class="px-4 py-3 font-medium">创建时间</th>
          <th class="px-4 py-3 font-medium">顺序</th>
          <th class="px-4 py-3 font-medium">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[var(--color-line)]">
        {assets.map((asset, index) => {
          const post = Array.isArray(asset.posts) ? asset.posts[0] : asset.posts;
          return (
            <tr>
              <td class="px-4 py-3"><img class="h-20 w-20 border border-[var(--color-line)] object-cover" src={asset.display_url || asset.public_url} alt={asset.alt || asset.file_name} loading="lazy" /></td>
              <td class="w-48 max-w-48 px-4 py-3">
                <p class="break-words font-medium">{asset.file_name}</p>
                <p class="mt-1 break-all text-xs text-[var(--color-muted)]">{asset.storage_path}</p>
              </td>
              <td class="whitespace-nowrap px-4 py-3">{asset.bucket === "private-media" ? "仅自己可见" : "公开"}</td>
              <td class="w-[320px] px-4 py-3">
                <form class="grid gap-2" method="post" action="/admin/media/action">
                  <input type="hidden" name="intent" value="meta" />
                  <input type="hidden" name="id" value={asset.id} />
                  <input type="hidden" name="next" value="/admin/gallery" />
                  <label class="grid gap-1">
                    <span class="text-xs text-[var(--color-muted)]">替代文字</span>
                    <input class="min-h-9 border border-[var(--color-line)] px-3 text-sm" name="alt" value={asset.alt ?? ""} placeholder="给读屏或加载失败时使用" />
                  </label>
                  <label class="grid gap-1">
                    <span class="text-xs text-[var(--color-muted)]">照片页说明</span>
                    <input class="min-h-9 border border-[var(--color-line)] px-3 text-sm" name="caption" value={asset.caption ?? ""} placeholder="可选，用于照片页展示" />
                  </label>
                  <AdminActionButton type="submit">保存</AdminActionButton>
                </form>
              </td>
              <td class="w-36 max-w-36 px-4 py-3">{post ? <a class="break-words font-medium hover:underline" href={`/admin/posts/${post.id}`}>{post.title}</a> : <span class="text-[var(--color-muted)]">未关联</span>}</td>
              <td class="whitespace-nowrap px-4 py-3 text-[var(--color-muted)]">{formatAdminDate(asset.created_at)}</td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <form method="post" action="/admin/media/action">
                    <input type="hidden" name="intent" value="gallery_order" />
                    <input type="hidden" name="id" value={asset.id} />
                    <input type="hidden" name="direction" value="up" />
                    <input type="hidden" name="next" value="/admin/gallery?success=sorted" />
                    <button class="inline-flex min-h-9 w-14 items-center justify-center border border-[var(--color-line)] bg-white px-2 text-xs font-medium text-[var(--color-ink)] transition hover:bg-[#f8f4ec] disabled:cursor-not-allowed disabled:opacity-40" type="submit" disabled={index === 0}>上移</button>
                  </form>
                  <form method="post" action="/admin/media/action">
                    <input type="hidden" name="intent" value="gallery_order" />
                    <input type="hidden" name="id" value={asset.id} />
                    <input type="hidden" name="direction" value="down" />
                    <input type="hidden" name="next" value="/admin/gallery?success=sorted" />
                    <button class="inline-flex min-h-9 w-14 items-center justify-center border border-[var(--color-line)] bg-white px-2 text-xs font-medium text-[var(--color-ink)] transition hover:bg-[#f8f4ec] disabled:cursor-not-allowed disabled:opacity-40" type="submit" disabled={index === assets.length - 1}>下移</button>
                  </form>
                </div>
              </td>
              <td class="px-4 py-3">
                <form method="post" action="/admin/media/action">
                  <input type="hidden" name="intent" value="featured" />
                  <input type="hidden" name="id" value={asset.id} />
                  <input type="hidden" name="featured" value="false" />
                  <input type="hidden" name="next" value="/admin/gallery" />
                  <AdminActionButton type="submit" variant="quiet">取消精选</AdminActionButton>
                </form>
              </td>
            </tr>
          );
        })}
      </tbody>
    </AdminTable>
  ) : (
    <AdminEmptyState title="还没有精选照片" description="可以在媒体页把图片设为精选，精选图片会显示在前台照片页。" />
  )}
</AdminLayout>

<script>
  const loadingOverlay = document.createElement("div");
  loadingOverlay.className = "fixed inset-0 z-50 hidden items-center justify-center bg-[#f7f5f1]/70 backdrop-blur-sm";
  loadingOverlay.innerHTML = '<div class="flex min-w-48 flex-col items-center gap-4 border border-[var(--color-line)] bg-white px-8 py-7 text-center shadow-sm"><span class="h-9 w-9 animate-spin rounded-full border-2 border-[var(--color-line)] border-t-[var(--color-ink)]"></span><span class="text-sm font-medium text-[var(--color-ink)]">正在处理...</span></div>';
  document.body.appendChild(loadingOverlay);

  document.addEventListener("submit", (event) => {
    if (!(event.target instanceof HTMLFormElement)) return;
    loadingOverlay.classList.remove("hidden");
    loadingOverlay.classList.add("flex");
  });
</script>
