---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SESSION_COOKIE_NAME, getCurrentUserFromToken } from "../lib/auth";

const currentUser = await getCurrentUserFromToken(Astro.cookies.get(SESSION_COOKIE_NAME)?.value);
const error = Astro.url.searchParams.get("error");
---

<BaseLayout title="注册 - 理哩的个人空间" currentUser={currentUser}>
  <section class="mx-auto grid max-w-4xl gap-5 md:grid-cols-[0.85fr_1.15fr]">
    <aside class="border border-[var(--color-line)] bg-[#f9f6ee] p-8">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">Reader</p>
      <h1 class="font-serif-title mt-4 text-4xl font-bold tracking-normal">注册</h1>
      <p class="mt-5 leading-8 text-[var(--color-muted)]">普通用户默认是读者身份，只能阅读公开且已发布的内容。</p>
    </aside>
    <form class="border border-[var(--color-line)] bg-[var(--color-panel)] p-8" method="post" action="/api/register" data-site-loading-form data-site-loading-message="正在注册..." data-site-loading-button-text="注册中...">
      {error && <p class="mb-5 border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700" role="alert">{error}</p>}
      <label class="block text-sm">
        <span class="text-[var(--color-muted)]">用户名</span>
        <input class="mt-2 min-h-11 w-full border border-[var(--color-line)] bg-white/70 px-3 py-2 outline-none focus:border-[var(--color-accent)]" name="username" autocomplete="username" required />
      </label>
      <label class="mt-5 block text-sm">
        <span class="text-[var(--color-muted)]">显示名</span>
        <input class="mt-2 min-h-11 w-full border border-[var(--color-line)] bg-white/70 px-3 py-2 outline-none focus:border-[var(--color-accent)]" name="display_name" autocomplete="name" />
      </label>
      <label class="mt-5 block text-sm">
        <span class="text-[var(--color-muted)]">密码</span>
        <input class="mt-2 min-h-11 w-full border border-[var(--color-line)] bg-white/70 px-3 py-2 outline-none focus:border-[var(--color-accent)]" name="password" type="password" autocomplete="new-password" required />
      </label>
      <button class="mt-7 min-h-11 w-full bg-[var(--color-accent)] px-4 py-3 text-sm font-medium text-[#fffdf7] hover:bg-[var(--color-ink)]" type="submit">注册</button>
      <p class="mt-5 text-sm text-[var(--color-muted)]">
        已有账号？<a class="text-[var(--color-ink)] underline underline-offset-4" href="/login">去登录</a>
      </p>
    </form>
  </section>
</BaseLayout>
