---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";

const currentUser = Astro.locals.currentUser;
---

<BaseLayout title="关于 - 理哩的个人空间" currentUser={currentUser}>
  <SectionHeader title="关于" note="给这个私人空间留一张扉页" />
  <section class="grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
    <aside class="border border-[var(--color-line)] bg-[var(--color-panel)] p-8">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">About Lili</p>
      <h2 class="font-serif-title mt-4 text-4xl font-bold leading-tight">理哩和她的个人空间</h2>
    </aside>
    <div class="space-y-5">
      <article class="border border-[var(--color-line)] bg-[var(--color-panel)] p-8">
        <h2 class="font-serif-title text-2xl font-semibold">关于理哩</h2>
        <p class="mt-4 leading-8 text-[var(--color-muted)]">
          这里先放一段安静的占位文字。它应该像博客扉页，不急着介绍所有事情，只留下写作者、生活、阅读和照片之间的关系。
        </p>
      </article>
      <article class="border border-[var(--color-line)] bg-[#efe7db] p-8">
        <h2 class="font-serif-title text-2xl font-semibold">关于这个网站</h2>
        <p class="mt-4 leading-8 text-[var(--color-muted)]">
          这个空间会长期保存统一文章、分类、标签、归档和照片。它不是产品官网，更像一本会慢慢增厚的私人杂志。
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
