---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MarkdownContent from "../../components/MarkdownContent.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import TagList from "../../components/TagList.astro";
import { canViewAllPosts, formatPostDate, getPostBySlugForViewer } from "../../lib/content";
import { getSiteSettingsWithDefaults } from "../../lib/site-settings";

export const prerender = false;

const currentUser = Astro.locals.currentUser;
const slug = Astro.params.slug ?? "";
const post = await getPostBySlugForViewer(slug, currentUser);
const showStatus = canViewAllPosts(currentUser);
const settings = await getSiteSettingsWithDefaults();

if (!post) {
  Astro.response.status = 404;
}
---

<BaseLayout title={post ? `${post.title} - ${settings.site_title}` : `文章不存在 - ${settings.site_title}`} currentUser={currentUser} settings={settings}>
  {post ? (
    <article class="mx-auto max-w-3xl">
      {post.cover_url ? (
        <header class="relative mx-auto overflow-hidden border border-[var(--color-line)] bg-[#ddd0c1]">
          <img class="aspect-[4/3] max-h-[560px] w-full object-cover sm:aspect-[16/9]" src={post.cover_url} alt={post.title} />
          <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/20 to-black/68"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 text-[#fffdf7] sm:p-10">
            <h1 class="font-serif-title max-w-3xl text-4xl font-bold leading-tight sm:text-6xl">{post.title}</h1>
            <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-[#fffdf7]/85">
              <time datetime={post.published_at ?? post.created_at}>{formatPostDate(post)}</time>
              {post.category && <a class="hover:text-white" href={`/categories/${post.category.slug}`}>{post.category.name}</a>}
            </div>
            {showStatus && (
              <div class="mt-4 flex flex-wrap gap-2">
                <StatusBadge status={post.status} visibility={post.visibility} noindex={post.noindex} />
              </div>
            )}
          </div>
        </header>
      ) : (
        <header class="mx-auto border border-[var(--color-line)] bg-[var(--color-panel)] p-6 sm:p-10">
          <h1 class="font-serif-title text-4xl font-bold leading-tight sm:text-6xl">{post.title}</h1>
          <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-xs text-[var(--color-muted)]">
            <time datetime={post.published_at ?? post.created_at}>{formatPostDate(post)}</time>
            {post.category && <a class="hover:text-[var(--color-ink)]" href={`/categories/${post.category.slug}`}>{post.category.name}</a>}
          </div>
          {showStatus && (
            <div class="mt-4 flex flex-wrap gap-2">
              <StatusBadge status={post.status} visibility={post.visibility} noindex={post.noindex} />
            </div>
          )}
        </header>
      )}

      <div class="mx-auto mt-10 border border-[var(--color-line)] bg-[var(--color-panel)] px-6 py-8 sm:px-10 sm:py-12">
        <MarkdownContent html={post.renderedHtml} />
        <div class="mt-10 space-y-5 border-t border-[var(--color-line)] pt-6 text-sm text-[var(--color-muted)]">
          <TagList tags={post.tags} />
          <p class="leading-7">
            {settings.post_copyright_notice}
          </p>
        </div>
      </div>
    </article>
  ) : (
    <section class="mx-auto max-w-xl border border-dashed border-[var(--color-line)] bg-[var(--color-panel)] p-8">
      <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">404</p>
      <h1 class="font-serif-title mt-3 text-3xl font-semibold">没有找到这篇文章</h1>
      <p class="mt-4 leading-7 text-[var(--color-muted)]">它可能不存在，或者当前账号没有阅读权限。</p>
      <a class="mt-6 inline-block min-h-11 py-3 text-sm underline underline-offset-4" href="/">回到首页</a>
    </section>
  )}
</BaseLayout>
