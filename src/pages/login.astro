---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SESSION_COOKIE_NAME, getCurrentUserFromToken } from "../lib/auth";

const currentUser = await getCurrentUserFromToken(Astro.cookies.get(SESSION_COOKIE_NAME)?.value);
const error = Astro.url.searchParams.get("error");
const next = Astro.url.searchParams.get("next") ?? "";
---

<BaseLayout title="登录 - 理哩的个人空间" currentUser={currentUser}>
  <section class="mx-auto grid max-w-4xl gap-5 md:grid-cols-[0.85fr_1.15fr]">
    <aside class="border border-[var(--color-line)] bg-[#efe7db] p-8">
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">Account</p>
      <h1 class="font-serif-title mt-4 text-4xl font-bold tracking-normal">登录</h1>
      <p class="mt-5 leading-8 text-[var(--color-muted)]">登录后继续作为读者浏览；管理员会在前台看到后台入口和非公开文章状态。</p>
    </aside>
    <form class="border border-[var(--color-line)] bg-[var(--color-panel)] p-8" method="post" action="/api/login" data-site-loading-form data-site-loading-message="正在登录..." data-site-loading-button-text="登录中...">
      {error && <p class="mb-5 border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700" role="alert">{error}</p>}
      <input type="hidden" name="next" value={next} />
      <label class="block text-sm">
        <span class="text-[var(--color-muted)]">用户名</span>
        <input class="mt-2 min-h-11 w-full border border-[var(--color-line)] bg-white/70 px-3 py-2 outline-none focus:border-[var(--color-accent)]" name="username" autocomplete="username" required />
      </label>
      <label class="mt-5 block text-sm">
        <span class="text-[var(--color-muted)]">密码</span>
        <input class="mt-2 min-h-11 w-full border border-[var(--color-line)] bg-white/70 px-3 py-2 outline-none focus:border-[var(--color-accent)]" name="password" type="password" autocomplete="current-password" required />
      </label>
      <button class="mt-7 min-h-11 w-full bg-[var(--color-accent)] px-4 py-3 text-sm font-medium text-[#fffdf7] hover:bg-[var(--color-ink)]" type="submit">登录</button>
      <p class="mt-5 text-sm text-[var(--color-muted)]">
        没有账号？<a class="text-[var(--color-ink)] underline underline-offset-4" href="/register">去注册</a>
      </p>
    </form>
  </section>
</BaseLayout>
