---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "后台 - 理哩的个人空间" } = Astro.props;
const currentUser = Astro.locals.currentUser;
const pathname = Astro.url.pathname;
const adminNavItems = [
  { href: "/admin", label: "Dashboard", text: "总览" },
  { href: "/admin/posts", label: "Posts", text: "文章" },
  { href: "/admin/categories", label: "Categories", text: "分类" },
  { href: "/admin/tags", label: "Tags", text: "标签" },
  { href: "/admin/media", label: "Media", text: "媒体" },
  { href: "/admin/gallery", label: "Gallery", text: "照片" },
  { href: "/admin/settings", label: "Settings", text: "设置" },
  { href: "/admin/users", label: "Users", text: "用户" },
];

function isActive(href: string) {
  if (href === "/admin") return pathname === href;
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[#f7f5f1] text-[var(--color-ink)]">
    <div class="min-h-screen lg:grid lg:grid-cols-[240px_1fr]">
      <aside class="border-b border-[var(--color-line)] bg-[#fdfbf7]/90 px-5 py-5 lg:border-b-0 lg:border-r">
        <a class="block font-serif-title text-xl font-semibold leading-tight" href="/admin">理哩后台</a>
        <p class="mt-2 text-xs leading-5 text-[var(--color-muted)]">写作、整理和回看。</p>
        <nav class="mt-7 flex gap-2 overflow-x-auto text-sm lg:flex-col" aria-label="后台导航">
          {adminNavItems.map((item) => (
            <a
              class={`flex min-h-10 items-center justify-between border px-3 py-2 transition ${isActive(item.href) ? "border-[var(--color-ink)] bg-[var(--color-ink)] text-white" : "border-transparent text-[var(--color-muted)] hover:border-[var(--color-line)] hover:bg-white hover:text-[var(--color-ink)]"}`}
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              data-admin-nav-link
            >
              <span>{item.text}</span>
              <span class="text-xs opacity-70">{item.label}</span>
            </a>
          ))}
        </nav>
      </aside>
      <div class="flex min-w-0 flex-col">
        <header class="flex flex-wrap items-center justify-between gap-3 border-b border-[var(--color-line)] bg-[#fdfbf7]/90 px-5 py-4 md:px-8">
          <span class="text-sm text-[var(--color-muted)]">后台基础框架</span>
          <div class="flex items-center gap-4 text-sm">
            {currentUser && <span class="text-[var(--color-muted)]">{currentUser.display_name || currentUser.username}</span>}
            <a class="font-medium text-[var(--color-muted)] hover:text-[var(--color-ink)]" href="/">前往前台</a>
            <form method="post" action="/api/logout">
              <button class="font-medium text-[var(--color-muted)] hover:text-[var(--color-ink)]" type="submit">退出</button>
            </form>
          </div>
        </header>
        <main class="flex-1 px-5 py-8 md:px-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<script>
  const adminLoadingOverlay = document.createElement("div");
  adminLoadingOverlay.className = "fixed inset-0 z-50 hidden items-center justify-center bg-[#f7f5f1]/70 backdrop-blur-sm";
  adminLoadingOverlay.innerHTML = '<div class="flex min-w-48 flex-col items-center gap-4 border border-[var(--color-line)] bg-white px-8 py-7 text-center shadow-sm"><span class="h-9 w-9 animate-spin rounded-full border-2 border-[var(--color-line)] border-t-[var(--color-ink)]"></span><span class="text-sm font-medium text-[var(--color-ink)]">正在打开...</span></div>';
  document.body.appendChild(adminLoadingOverlay);

  const prefetched = new Set();

  function showAdminLoading() {
    adminLoadingOverlay.classList.remove("hidden");
    adminLoadingOverlay.classList.add("flex");
  }

  function prefetchAdminPage(link: Element | null) {
    if (!(link instanceof HTMLAnchorElement)) return;
    const url = new URL(link.href);
    if (url.origin !== window.location.origin || prefetched.has(url.href)) return;
    prefetched.add(url.href);
    void fetch(url.href, { credentials: "same-origin", priority: "low" }).catch(() => {
      prefetched.delete(url.href);
    });
  }

  document.addEventListener("pointerenter", (event) => {
    const link = event.target instanceof HTMLElement ? event.target.closest("[data-admin-nav-link]") : null;
    prefetchAdminPage(link);
  }, { capture: true });

  document.addEventListener("focusin", (event) => {
    const link = event.target instanceof HTMLElement ? event.target.closest("[data-admin-nav-link]") : null;
    prefetchAdminPage(link);
  });

  document.addEventListener("click", (event) => {
    const link = event.target instanceof HTMLElement ? event.target.closest("[data-admin-nav-link]") : null;
    if (!(link instanceof HTMLAnchorElement)) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || link.target) return;
    showAdminLoading();
  });
</script>
