---
interface Props {
  html: string;
}

const { html } = Astro.props;
---

<article class="markdown-content font-serif-title max-w-none text-lg leading-9 text-[#38302a]" set:html={html} />

<style>
  .markdown-content {
    --color-markdown-accent: #71afdd;
    --color-markdown-muted: #767676;
  }

  .markdown-content :global(h1),
  .markdown-content :global(h2),
  .markdown-content :global(h3) {
    color: var(--color-ink);
    font-weight: 700;
    line-height: 1.25;
    margin: 2.1em 0 0.7em;
  }

  .markdown-content :global(h1) {
    font-size: 2.25rem;
  }

  .markdown-content :global(h2) {
    font-size: 1.75rem;
  }

  .markdown-content :global(p),
  .markdown-content :global(ul),
  .markdown-content :global(ol),
  .markdown-content :global(blockquote) {
    margin: 1.25em 0;
  }

  .markdown-content :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-markdown-accent);
    text-underline-offset: 4px;
  }

  .markdown-content :global(strong),
  .markdown-content :global(b),
  .markdown-content :global(em),
  .markdown-content :global(i) {
    color: var(--color-markdown-accent);
  }

  .markdown-content :global(blockquote) {
    border-left: 3px solid var(--color-markdown-accent);
    color: var(--color-markdown-muted);
    font-size: 1rem;
    line-height: 1.85;
    padding: 0.1rem 0 0.1rem 1rem;
    position: relative;
  }

  .markdown-content :global(blockquote::before) {
    color: var(--color-markdown-accent);
    content: "\201C";
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.2rem;
  }

  .markdown-content :global(blockquote p) {
    color: var(--color-markdown-muted);
    margin-top: 0;
  }

  .markdown-content :global(img) {
    margin: 2rem 0;
    border-radius: 4px;
    width: 100%;
  }

  .markdown-content :global(video),
  .markdown-content :global(audio),
  .markdown-content :global(iframe) {
    display: block;
    margin: 2rem auto;
    max-width: 100%;
  }

  .markdown-content :global(iframe) {
    width: 100%;
  }

  .markdown-content :global(code) {
    background: #efe7db;
    border-radius: 4px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.86em;
    padding: 0.1rem 0.3rem;
  }

  .markdown-content :global(pre) {
    background: #25211d;
    color: #fffdf7;
    overflow-x: auto;
    padding: 1rem;
  }
</style>
