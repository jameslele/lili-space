---
interface Props {
  title: string;
  note?: string;
  level?: "h1" | "h2";
}

const { title, note, level = "h1" } = Astro.props;
---

<div class="mb-5 mt-14 flex items-end justify-between gap-6 border-t-[3px] border-[var(--color-ink)] pt-4">
  {level === "h1" ? (
    <h1 class="font-serif-title text-3xl font-bold leading-tight sm:text-4xl">{title}</h1>
  ) : (
    <h2 class="font-serif-title text-3xl font-bold leading-tight sm:text-4xl">{title}</h2>
  )}
  {note && <p class="hidden text-right text-sm text-[var(--color-muted)] sm:block">{note}</p>}
</div>
