---
import type { CategorySummary } from "../lib/content";

interface Props {
  category: CategorySummary;
}

const { category } = Astro.props;
const description = category.description?.trim();
const postCount = category.postCount ?? 0;
const shouldCollapseDescription = Boolean(description && description.length > 64);
---

<article class="group flex min-h-36 flex-col border-b border-r border-[var(--color-line)] bg-[var(--color-panel)] p-5 transition hover:bg-[#f0e7d9]">
  <a class="font-serif-title block text-xl font-semibold transition hover:text-[var(--color-accent)]" href={`/categories/${category.slug}`}>
    {category.name}
  </a>
  <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{postCount} 篇文章</p>
  {
    description && (
      shouldCollapseDescription ? (
        <details class="group mt-3 text-sm leading-6 text-[var(--color-muted)]">
          <summary class="cursor-pointer list-none">
            <span class="line-clamp-2 group-open:hidden">{description}</span>
            <span class="mt-1 inline-block text-xs font-medium text-[var(--color-ink)] group-open:hidden">显示全部</span>
            <span class="hidden text-xs font-medium text-[var(--color-ink)] group-open:inline-block">收起</span>
          </summary>
          <p class="mt-2 break-words">{description}</p>
        </details>
      ) : (
        <p class="mt-3 line-clamp-2 text-sm leading-6 text-[var(--color-muted)]">{description}</p>
      )
    )
  }
  <a class="mt-auto pt-5 text-xs font-medium text-[var(--color-muted)] transition hover:text-[var(--color-ink)]" href={`/categories/${category.slug}`}>
    查看文章
  </a>
</article>
