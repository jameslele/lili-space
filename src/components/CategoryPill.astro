---
import type { CategorySummary } from "../lib/content";

interface Props {
  category: CategorySummary;
}

const { category } = Astro.props;
---

<a class="group block min-h-28 border-b border-r border-[var(--color-line)] bg-[var(--color-panel)] p-5 transition hover:bg-[#f0e7d9]" href={`/categories/${category.slug}`}>
  <span class="font-serif-title block text-xl font-semibold">{category.name}</span>
  <span class="mt-3 block text-sm leading-6 text-[var(--color-muted)]">
    {category.description || `${category.postCount ?? 0} 篇文章`}
  </span>
</a>
