---
import type { PostSummary } from "../lib/content";
import { formatPostDate } from "../lib/content";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  post: PostSummary;
  showStatus?: boolean;
}

const { post, showStatus = false } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs text-[var(--color-muted)]">
  <time datetime={post.published_at ?? post.created_at}>{formatPostDate(post)}</time>
  {post.category && <a class="hover:text-[var(--color-ink)]" href={`/categories/${post.category.slug}`}>{post.category.name}</a>}
  {post.tags.slice(0, 3).map((tag) => <a class="hover:text-[var(--color-ink)]" href={`/tags/${tag.slug}`}>#{tag.name}</a>)}
  {showStatus && <StatusBadge status={post.status} visibility={post.visibility} />}
</div>
