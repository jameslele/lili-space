---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<section class="border border-dashed border-[var(--color-line)] bg-[var(--color-panel)] p-8">
  <h2 class="font-serif-title text-2xl font-semibold">{title}</h2>
  <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">{description}</p>
</section>
