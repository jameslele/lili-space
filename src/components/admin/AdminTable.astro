---
interface Props {
  labelledBy?: string;
}

const { labelledBy } = Astro.props;
---

<div class="border border-[var(--color-line)] bg-white">
  <p class="border-b border-[var(--color-line)] bg-[#f8f4ec] px-3 py-2 text-xs text-[var(--color-muted)] md:hidden">
    横向滑动查看完整表格
  </p>
  <div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-[var(--color-line)] text-left text-sm" aria-labelledby={labelledBy}>
    <slot />
  </table>
  </div>
</div>
