---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-6 border-b border-[var(--color-line)] pb-5">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">{eyebrow}</p>}
      <h1 class="font-serif-title text-3xl font-semibold leading-tight text-[var(--color-ink)]">{title}</h1>
      {description && <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--color-muted)]">{description}</p>}
    </div>
    <div class="flex flex-wrap gap-2">
      <slot />
    </div>
  </div>
</header>
