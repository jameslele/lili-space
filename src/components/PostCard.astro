---
import type { PostSummary } from "../lib/content";
import { getPostExcerpt } from "../lib/content";
import PostMeta from "./PostMeta.astro";

interface Props {
  post: PostSummary;
  variant?: "cover" | "stack" | "feature" | "row";
  showStatus?: boolean;
}

const { post, variant = "feature", showStatus = false } = Astro.props;
const cover = post.cover_url;
const fallbackClass = "bg-[linear-gradient(135deg,#ddd0c1,#efe7db_46%,#c9b292)]";
---

{variant === "cover" && (
  <article class="group relative min-h-[430px] overflow-hidden bg-[#ddd0c1] md:min-h-[570px]">
    {cover ? <img class="absolute inset-0 h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]" src={cover} alt={post.title} /> : <div class={`absolute inset-0 ${fallbackClass}`} />}
    <div class="absolute inset-0 bg-gradient-to-b from-transparent from-35% to-black/65"></div>
    <a class="absolute inset-0 z-10" href={`/posts/${post.slug}`} aria-label={`阅读 ${post.title}`}></a>
    <div class="absolute bottom-0 left-0 right-0 z-20 p-7 text-[#fffdf7] sm:p-9">
      <PostMeta post={post} showStatus={showStatus} />
      <h1 class="font-serif-title mt-4 max-w-3xl text-5xl font-bold leading-[1.05] sm:text-6xl lg:text-7xl">{post.title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-8 text-[#fffdf7]/90">{getPostExcerpt(post)}</p>
    </div>
  </article>
)}

{variant === "stack" && (
  <article class="grid min-h-64 grid-cols-[42%_1fr] border border-[var(--color-line)] bg-[var(--color-panel)]">
    <a class="block overflow-hidden bg-[#ddd0c1]" href={`/posts/${post.slug}`} aria-label={`阅读 ${post.title}`}>
      {cover ? <img class="h-full w-full object-cover transition duration-300 hover:scale-[1.03]" src={cover} alt={post.title} /> : <div class={`h-full min-h-64 ${fallbackClass}`} />}
    </a>
    <div class="p-5 sm:p-6">
      <PostMeta post={post} showStatus={showStatus} />
      <h2 class="font-serif-title mt-3 text-2xl font-semibold leading-tight sm:text-3xl">
        <a class="hover:text-[var(--color-accent)]" href={`/posts/${post.slug}`}>{post.title}</a>
      </h2>
      <p class="mt-3 line-clamp-4 text-sm leading-7 text-[var(--color-muted)]">{getPostExcerpt(post)}</p>
    </div>
  </article>
)}

{variant === "feature" && (
  <article class="border border-[var(--color-line)] bg-[var(--color-panel)]">
    <a class="block aspect-[4/3] overflow-hidden bg-[#d9c7b4]" href={`/posts/${post.slug}`} aria-label={`阅读 ${post.title}`}>
      {cover ? <img class="h-full w-full object-cover transition duration-300 hover:scale-[1.03]" src={cover} alt={post.title} /> : <div class={`h-full ${fallbackClass}`} />}
    </a>
    <div class="p-5 sm:p-6">
      <PostMeta post={post} showStatus={showStatus} />
      <h2 class="font-serif-title mt-3 text-2xl font-semibold leading-snug">
        <a class="hover:text-[var(--color-accent)]" href={`/posts/${post.slug}`}>{post.title}</a>
      </h2>
      <p class="mt-3 line-clamp-3 text-sm leading-7 text-[var(--color-muted)]">{getPostExcerpt(post)}</p>
    </div>
  </article>
)}

{variant === "row" && (
  <article class="grid gap-3 border-b border-[var(--color-line)] py-5 sm:grid-cols-[112px_1fr] sm:gap-6">
    <time class="text-sm font-semibold text-[var(--color-muted)]" datetime={post.published_at ?? post.created_at}>{new Date(post.published_at ?? post.created_at).toLocaleDateString("zh-CN", { month: "2-digit", day: "2-digit" })}</time>
    <div>
      <div class="mb-2"><PostMeta post={post} showStatus={showStatus} /></div>
      <h3 class="font-serif-title text-2xl font-semibold leading-tight">
        <a class="hover:text-[var(--color-accent)]" href={`/posts/${post.slug}`}>{post.title}</a>
      </h3>
      <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{getPostExcerpt(post)}</p>
    </div>
  </article>
)}
