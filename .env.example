# Runtime: server-side Supabase connection
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Runtime: browser-side Supabase connection used by client bundles, if needed
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Runtime: bucket names used by the app
SUPABASE_STORAGE_PUBLIC_BUCKET=public-media
SUPABASE_STORAGE_PRIVATE_BUCKET=private-media

# Runtime/build: allowed browser origins for form POSTs and trusted deployed domains
# Use comma-separated full origins when keeping both EdgeOne preview and a custom domain.
SITE_ALLOWED_ORIGINS=https://lili-space-only-mainland-k5jdl5gj.zh-cn.edgeone.cool

# Local Supabase CLI / migration scripts only
SUPABASE_DB_PASSWORD=
